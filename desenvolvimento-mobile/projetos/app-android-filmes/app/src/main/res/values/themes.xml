<?xml version="1.0" encoding="utf-8"?>

<!-- Configura temas app -->

<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema principal app -->
    <style name="Theme.FlexFilmes" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Cor primária -->
        <item name="colorPrimary">#000000</item>

        <!-- Variante cor primária -->
        <item name="colorPrimaryVariant">#000000</item>

        <!-- Cor sobre primária -->
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Cor status bar -->
        <item name="android:statusBarColor">#000000</item>

    </style>

    <!-- Estilo texto menu lateral -->
    <style name="NavMenuItemAppearance" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Estilo título toolbar -->
    <style name="Toolbar.Title" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

</resources>