<?xml version="1.0" encoding="utf-8"?>

<!-- Header menu lateral -->

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:background="@color/drawer_header_bg"
    android:padding="16dp"
    android:gravity="bottom">

    <!-- Avatar usuário -->
    <ImageView
        android:id="@+id/drawer_header_avatar"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:src="@drawable/profile_avatar"
        android:contentDescription="@string/profile_avatar"
        android:scaleType="centerCrop"
        android:layout_marginBottom="8dp" />

    <!-- Nome usuário -->
    <TextView
        android:id="@+id/drawer_header_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/guest_user"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

    <!-- Email usuário -->
    <TextView
        android:id="@+id/drawer_header_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/guest_email"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:layout_marginTop="2dp" />

</LinearLayout>