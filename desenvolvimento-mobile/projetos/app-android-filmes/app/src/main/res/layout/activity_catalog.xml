<?xml version="1.0" encoding="utf-8"?>

<!-- Tela principal catálogo filmes -->

<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- Container conteúdo principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar padrão app -->
        <include
            layout="@layout/toolbar_flexfilmes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Scroll conteúdo tela -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <!-- Container listas filmes -->
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp">

                <!-- Seção continue assistindo -->
                <TextView
                    android:id="@+id/label_continue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_continue"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginTop="8dp"/>

                <!-- Lista filmes continue -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_continue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp" />

                <!-- Seção minha lista -->
                <TextView
                    android:id="@+id/label_mylist"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_mylist"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"/>

                <!-- Lista filmes minha lista -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_mylist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp" />

                <!-- Seção top picks -->
                <TextView
                    android:id="@+id/label_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_top"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"/>

                <!-- Lista filmes top picks -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_top"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp" />

                <!-- Seção recentes -->
                <TextView
                    android:id="@+id/label_recent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_recent"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_marginTop="16dp"/>

                <!-- Lista filmes recentes -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_recent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp" />

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Menu lateral drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        android:background="@color/drawer_background"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/drawer_header"
        app:itemIconTint="@color/white"
        app:itemTextColor="@color/white"
        app:itemTextAppearance="@style/NavMenuItemAppearance" />

</androidx.drawerlayout.widget.DrawerLayout>